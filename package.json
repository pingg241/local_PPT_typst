{
  "name": "typst-ppt-addin",
  "version": "1.0.0",
  "packageManager": "npm@11.6.2",
  "scripts": {
    "bridge": "node local-bridge/server.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite --config .config/vite.config.js",
    "build": "vite build --config .config/vite.config.js",
    "lint": "eslint web .config --config .config/eslint.mjs --max-warnings 0 --no-warn-ignored",
    "start": "office-addin-debugging start manifest.xml desktop",
    "stop": "office-addin-debugging stop manifest.xml",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate": "office-addin-manifest validate manifest.xml",
    "validate-prod": "npm run generate-prod-manifest && office-addin-manifest validate -p manifest.prod.xml",
    "generate-prod-manifest": "node scripts/generate-prod-manifest.mjs"
  },
  "devDependencies": {
    "@eslint/css": "^0.14.1",
    "@html-eslint/eslint-plugin": "^0.52.1",
    "@stylistic/eslint-plugin": "^5.7.0",
    "@types/office-js": "^1.0.586",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "office-addin-debugging": "^6.0.4",
    "office-addin-manifest": "^2.1.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "monaco-editor": "^0.55.1",
    "ws": "^8.20.0"
  }
}
